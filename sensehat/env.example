# Claudometer Sense HAT credentials template.
# Copy this to a file named ".env" at the repo root (or sensehat/.env) and fill
# in your values, then run:
#   uv run --no-project --with requests --with sense-emu python -m sensehat.app --emulator
#
# These are the same values the Windows tray app stores in its config.json.
# Every .env file is git-ignored, so your secrets won't be committed. This
# template is intentionally named "env.example" (no leading dot) so it stays
# tracked WITHOUT ever holding real secrets.

# Organization UUID from the URL at https://claude.ai/settings/usage
CLAUDOMETER_ORG_ID=

# The "sessionKey" cookie from claude.ai
# (F12 -> Application -> Cookies -> https://claude.ai -> sessionKey)
CLAUDOMETER_SESSION_COOKIE=

# Optional overrides:
# CLAUDOMETER_DEVICE_ID=          # any UUID; auto-generated if omitted
# CLAUDOMETER_POLL_INTERVAL=300   # seconds between API polls
